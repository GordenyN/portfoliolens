      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Check if Qdrant found a near-duplicate (cosine similarity > 0.82)\nconst result = $input.item.json;\nconst hits = result.result || [];\n\nif (hits.length > 0 && hits[0].score >= 0.82) {\n  // Duplicate found — skip this article\n  return { json: { is_duplicate: true, score: hits[0].score } };\n} else {\n  // New article — pass through with embedding\n  return { json: { is_duplicate: false, ...result } };\n}\n"
      },
