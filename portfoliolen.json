    {
      "parameters": {
        "method": "POST",
        "url": "https://2449cd38-54c0-4cae-9f73-85217ac3a273.eu-west-1-0.aws.cloud.qdrant.io:6333/collections/financial_news/points/search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "api-key"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"vector\": {{ JSON.stringify($json.embedding.values) }},\n  \"limit\": 20,\n  \"score_threshold\": 0.55,\n  \"with_payload\": true\n}",
        "options": {}
      },
      "id": "f843e800-b0e5-4fe2-9d1d-86b32306eaf6",
      "name": "Qdrant — Search by Ticker",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        672,
        896
      ],
      "notes": "Векторный поиск в Qdrant с фильтром по тикеру"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Process Qdrant search results for each ticker\n// Filter by ticker in code since Qdrant collection has no index\n\nconst ticker = $('Extract Tickers').item.json.ticker;\nconst searchResult = $input.item.json;\nconst hits = searchResult.result || [];\n\n// Filter hits to only include articles mentioning this ticker\nconst relevantHits = hits.filter(hit => {\n  const tickers = hit.payload.tickers || [];\n  return tickers.includes(ticker);\n});\n\n// Helper to extract hostname from URL without using URL constructor\nfunction getHostname(url) {\n  if (!url) return 'Unknown';\n  return url\n    .replace(/^https?:\\/\\//i, '')\n    .split('/')[0]\n    .replace('www.', '')\n    .toLowerCase();\n}\n\nconst articles = relevantHits.map((hit, idx) => ({\n  id: hit.id || idx,\n  ticker: ticker,\n  title: hit.payload.title,\n  url: hit.payload.url,\n  date: hit.payload.date,\n  sentiment: hit.payload.tone,\n  score: hit.payload.sentiment_score,\n  summary: hit.payload.summary,\n  source: getHostname(hit.payload.url),\n  vector_score: hit.score\n}));\n\nreturn { json: { ticker, articles } };\n"
      },
      "id": "03ec4771-8c31-4e79-8d2c-b1b4ef510ec6",
      "name": "Format Search Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        896,
        896
      ]
    },
    {
      "parameters": {
        "aggregate": "aggregateAllItemData",
        "destinationFieldName": "results",
        "options": {}
      },
      "id": "6047612e-7a3d-4db5-a78b-f02c69c04ed2",
      "name": "Aggregate All Ticker Results",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [
        1120,
        896
      ],
      "notes": "Объединяем результаты по всем тикерам в один объект"
    },
    {
      "parameters": {
        "jsCode": "// Build the news map {AAPL: [...], NVDA: [...]} from aggregated results\nconst results = items[0].json.results || [];\n\nconst newsMap = {};\nconst allArticles = [];\n\nfor (const item of results) {\n  const ticker = item.ticker;\n  const articles = item.articles || [];\n  newsMap[ticker] = articles;\n  allArticles.push(...articles);\n}\n\n// Build context string for Gemini digest\nconst context = Object.entries(newsMap).map(([ticker, arts]) => {\n  if (!arts.length) return `${ticker}: No recent news found.`;\n  return `${ticker}:\\n` + arts.map(a => `  - [${a.sentiment?.toUpperCase()}] ${a.title}: ${a.summary}`).join('\\n');\n}).join('\\n\\n');\n\nreturn [{ json: { newsMap, allArticles, context, tickers: Object.keys(newsMap) } }];\n"
      },
      "id": "c8dcc23c-47f5-4a5e-ae1f-a97304e3d7e7",
      "name": "Build News Map",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1344,
        896
      ]
    },
