      "name": "POST /portfolio Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        896
      ],
      "webhookId": "3e5edbf9-27dd-417a-8975-045f2eb62efe",
      "notes": "Принимает POST {tickers: ['AAPL', 'NVDA', 'BTC']} с фронтенда"
    },
    {
      "parameters": {
        "jsCode": "// Extract tickers from webhook body\n// Supports both {tickers: [...]} and plain array\nconst body = items[0].json.body;\nlet tickers = [];\n\nif (typeof body === \"string\") {\n  // Parse JSON string\n  try {\n    const parsed = JSON.parse(body);\n    tickers = Array.isArray(parsed) ? parsed : (parsed.tickers || []);\n  } catch (e) {\n    throw new Error(\"Invalid JSON in body. Send array or {tickers: [...]}.\");\n  }\n} else if (Array.isArray(body)) {\n  tickers = body;\n} else if (body && body.tickers) {\n  tickers = body.tickers;\n}\n\nif (!tickers.length) {\n  throw new Error(\"No tickers provided. Send array or {tickers: [...]}.\");\n}\n\n// Create one item per ticker for parallel processing\nreturn tickers.map(ticker => ({\n  json: { ticker: ticker.toUpperCase().trim() }\n}));\n"
      },
      "id": "e301f157-ed63-490e-ad65-707fde6f422f",
      "name": "Extract Tickers",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
