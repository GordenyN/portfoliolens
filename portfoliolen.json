    {
      "parameters": {
        "jsCode": "function uuidFromString(str) {\n  let hash = 0;\n  for (let i = 0; i < str.length; i++) {\n    hash = ((hash << 5) - hash) + str.charCodeAt(i);\n    hash |= 0;\n  }\n  const h = Math.abs(hash).toString(16).padStart(8, '0');\n  const h2 = Math.abs(hash * 2654435761).toString(16).padStart(8, '0');\n  return `${h.substring(0,8)}-${h2.substring(0,4)}-4${h.substring(1,4)}-a${h2.substring(4,7)}-${h.substring(0,4)}${h2.substring(0,8)}`;\n}\n\nreturn items.map(item => ({\n  json: {\n    ...item.json,\n    article_id: uuidFromString(item.json.url)\n  }\n}));"
      },
