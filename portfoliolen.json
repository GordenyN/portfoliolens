      "parameters": {
        "jsCode": "// Нормализуем RSS item в стандартный формат\nreturn items.map(item => {\n    const link = item.json.link || '';\n    \n    let source = 'rss';\n    if (link) {\n        // Парсим hostname без использования URL (чтобы избежать \"URL is not defined\")\n        source = link\n            .replace(/^https?:\\/\\//i, '')   // убираем http:// или https://\n            .split('/')[0]                  // берём первую часть до /\n            .replace('www.', '')            // убираем www.\n            .toLowerCase();\n    }\n\n    return {\n        json: {\n            title: item.json.title || '',\n            url: link,\n            date: item.json.pubDate \n                ? new Date(item.json.pubDate).toISOString().split('T')[0] \n                : new Date().toISOString().split('T')[0],\n            source: source\n        }\n    };\n});"
      },
